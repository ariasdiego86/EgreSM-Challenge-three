@model MiniSalesOrderApp.Web.ViewModels.Orders.AddProductViewModel

@{
    ViewData["Title"] = "Add Product";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h1 class="h4 mb-1">Add Product</h1>
                <p class="text-muted">Order: <strong>@Model.CustomerName</strong></p>

                <form asp-action="AddProduct" method="post" novalidate>
                    <input asp-for="OrderId" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="ProductName" class="form-label"></label>
                        <input asp-for="ProductName" class="form-control" placeholder="Product name" />
                        <span asp-validation-for="ProductName" class="text-danger"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="Quantity" class="form-label"></label>
                            <input asp-for="Quantity" class="form-control" type="number" min="1" />
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="UnitPrice" class="form-label"></label>
                            <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" min="0.01" />
                            <span asp-validation-for="UnitPrice" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">Add Product</button>
                        <a asp-action="Details" asp-route-id="@Model.OrderId" class="btn btn-outline-secondary">Back to Order</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
